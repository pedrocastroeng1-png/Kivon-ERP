# GEMINI_API_KEY: Required for Gemini AI API calls.
# The platform automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# The platform automatically injects this at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase configuration
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"

# Initial admin bootstrap credentials
INITIAL_ADMIN_EMAIL="pedrotargos@gmail.com"
INITIAL_ADMIN_PASSWORD="KivonAdmin2026!"
